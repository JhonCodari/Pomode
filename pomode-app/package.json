{
  "name": "pomode-app",
  "version": "1.0.1",
  "description": "Aplicativo web de Pomodoro para aumentar sua produtividade",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "prebuild": "node scripts/set-version.js",
    "build": "ng build",
    "build:prod": "ng build --configuration production --base-href /",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "deploy": "echo 'Deploy de producao e feito apenas pela esteira (push na main ou workflow_dispatch em .github/workflows/deploy.yml).' && exit 1",
    "deploy:preview": "npm run build:prod"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.15",
    "@angular/compiler": "^21.2.15",
    "@angular/core": "^21.2.15",
    "@angular/forms": "^21.2.15",
    "@angular/platform-browser": "^21.2.15",
    "@angular/platform-browser-dynamic": "^21.2.15",
    "@angular/router": "^21.2.15",
    "@ngx-translate/core": "^17.0.0",
    "@ngx-translate/http-loader": "^16.0.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^21.2.13",
    "@angular/cli": "^21.2.13",
    "@angular/compiler-cli": "^21.2.15",
    "@types/jasmine": "~5.1.0",
    "jasmine-core": "~5.6.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3"
  },
  "overrides": {
    "uuid": "11.1.1",
    "webpack-dev-server": "5.2.4"
  }
}
